<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <children>
                <flow-layout direction="horizontal" id="closeBtn">
                    <children/>
                    <sizing>
                        <horizontal method="fixed">60</horizontal>
                        <vertical method="fixed">20</vertical>
                    </sizing>
                    <margins>
                        <left>10</left>
                        <top>10</top>
                    </margins>
                </flow-layout>
                <flow-layout direction="horizontal">
                    <children>
                        <!--                <scroll direction="vertical">-->
                        <!--                    <flow-layout direction="vertical" id="places">-->
                        <!--                        <children>-->
                        <!--                        </children>-->
                        <!--                    </flow-layout>-->
                        <!--                    <scrollbar-thiccness>5</scrollbar-thiccness>-->
                        <!--                    <scrollbar-color>dark-gray</scrollbar-color>-->
                        <!--                    <padding><all>10</all></padding>-->
                        <!--                    <surface>-->
                        <!--                        <panel/>-->
                        <!--                    </surface>-->
                        <!--                    <allow-overflow>true</allow-overflow>-->
                        <!--                    <sizing>-->
                        <!--                        <vertical method="fill">90</vertical>-->
                        <!--                        <horizontal method="fill">25</horizontal>-->
                        <!--                    </sizing>-->
                        <!--                </scroll>-->
                        <scroll direction="vertical">
                            <flow-layout direction="vertical" id="dateTimes">
                                <children>
                                    <label id="scroll-empty">
                                        <text translate="true"/>
                                        <horizontal-text-alignment>center</horizontal-text-alignment>
                                        <vertical-text-alignment>top</vertical-text-alignment>
                                    </label>
                                </children>
                                <allow-overflow>true</allow-overflow>
                            </flow-layout>
                            <surface>
                                <flat>#232323</flat>
                                <outline>#343434</outline>
                            </surface>
                            <padding><all>10</all></padding>
                            <scrollbar-color>dark-gray</scrollbar-color>
                            <scrollbar-thiccness>5</scrollbar-thiccness>
                            <sizing>
                                <vertical method="fill">100</vertical>
                                <horizontal method="fill">40</horizontal>
                            </sizing>
                        </scroll>
                        <flow-layout direction="vertical" id="snapshotContainer">
                            <children>
                                <flow-layout direction="horizontal">
                                    <children>
                                        <flow-layout direction="vertical">
                                            <children>
                                                <label>
                                                    <text translate="true">gui.deathmemo.pos</text>
                                                    <horizontal-text-alignment>left</horizontal-text-alignment>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                </label>
                                                <label id="posX">
                                                    <text/>
                                                    <horizontal-text-alignment>left</horizontal-text-alignment>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                    <margins>
                                                        <top>10</top>
                                                    </margins>
                                                </label>
                                                <label id="posY">
                                                    <text/>
                                                    <horizontal-text-alignment>left</horizontal-text-alignment>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                    <margins>
                                                        <top>10</top>
                                                    </margins>
                                                </label>
                                                <label id="posZ">
                                                    <text/>
                                                    <horizontal-text-alignment>left</horizontal-text-alignment>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                    <margins>
                                                        <top>10</top>
                                                    </margins>
                                                </label>
                                            </children>
                                            <sizing>
                                                <vertical method="fill">100</vertical>
                                                <horizontal method="fill">50</horizontal>
                                            </sizing>
                                        </flow-layout>
                                        <flow-layout direction="vertical">
                                            <children>
                                                <!-- Броня -->
                                                <flow-layout direction="vertical">
                                                    <children>
                                                        <label>
                                                            <vertical-text-alignment>center</vertical-text-alignment>
                                                            <horizontal-text-alignment>left</horizontal-text-alignment>
                                                            <text translate="true">gui.deathmemo.armor</text>
                                                            <color>#EAEAEA</color>
                                                        </label>
                                                        <grid-layout rows="1" columns="4" id="armor">
                                                            <children/>
                                                            <sizing>
                                                                <horizontal method="fixed">72</horizontal>
                                                                <vertical method="fixed">18</vertical>
                                                            </sizing>
                                                            <horizontal-alignment>left</horizontal-alignment>
                                                        </grid-layout>
                                                    </children>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                    <padding>
                                                        <bottom>10</bottom>
                                                    </padding>
                                                    <horizontal-alignment>left</horizontal-alignment>
                                                </flow-layout>

                                                <!-- Вторая рука -->
                                                <flow-layout direction="vertical">
                                                    <children>
                                                        <label>
                                                            <text translate="true">gui.deathmemo.offhand</text>
                                                            <color>#EAEAEA</color>
                                                            <vertical-text-alignment>center</vertical-text-alignment>
                                                        </label>
                                                        <flow-layout direction="horizontal" id="offhand">
                                                            <children/>
                                                            <horizontal-alignment>center</horizontal-alignment>
                                                            <sizing>
                                                                <vertical method="fixed">18</vertical>
                                                                <horizontal method="fixed">18</horizontal>
                                                            </sizing>
                                                        </flow-layout>
                                                    </children>
                                                    <horizontal-alignment>left</horizontal-alignment>
                                                    <sizing>
                                                        <horizontal method="fill">100</horizontal>
                                                    </sizing>
                                                </flow-layout>
                                            </children>
                                            <sizing>
                                                <horizontal method="fill">50</horizontal>
                                                <vertical method="fill">100</vertical>
                                            </sizing>
                                            <vertical-alignment>top</vertical-alignment>
                                            <horizontal-alignment>right</horizontal-alignment>
                                        </flow-layout>
                                    </children>
                                    <sizing>
                                        <vertical method="fill">50</vertical>
                                        <horizontal method="fill">100</horizontal>
                                    </sizing>
                                </flow-layout>
                                <grid-layout rows="4" columns="9" id="items">
                                    <children/>
                                    <sizing>
                                        <horizontal method="fixed">162</horizontal>
                                        <vertical method="fixed">72</vertical>
                                    </sizing>
                                    <vertical-alignment>bottom</vertical-alignment>
                                    <horizontal-alignment>left</horizontal-alignment>
                                </grid-layout>
                            </children>
                            <surface>
                                <flat>#1D1D1D</flat>
                                <outline>#2E2E2E</outline>
                            </surface>
                            <sizing>
                                <vertical method="fill">100</vertical>
                                <horizontal method="fill">60</horizontal>
                            </sizing>
                            <padding><all>10</all></padding>
                            <vertical-alignment>center</vertical-alignment>
                            <horizontal-alignment>center</horizontal-alignment>
                        </flow-layout>
                    </children>
                    <padding><all>10</all></padding>
                    <horizontal-alignment>center</horizontal-alignment>
                    <vertical-alignment>center</vertical-alignment>
                    <sizing>
                        <vertical method="fill">90</vertical>
                    </sizing>
                </flow-layout>
            </children>
            <sizing>
                <vertical method="fill">100</vertical>
                <horizontal method="fill">100</horizontal>
            </sizing>
            <surface>
                <vanilla-translucent/>
            </surface>
        </flow-layout>
    </components>
    <templates>
        <template name="itemSlot">
            <flow-layout direction="vertical">
                <children>
                    <sprite atlas="minecraft:textures/atlas/gui.png" sprite="minecraft:container/slot">
                        <sizing>
                            <horizontal method="fill">100</horizontal>
                            <vertical method="fill">100</vertical>
                        </sizing>
                    </sprite>
                    <item id="item">
                        <positioning type="absolute">1,1</positioning>
                        <set-tooltip-from-stack>false</set-tooltip-from-stack>
                        <sizing>
                            <vertical method="fixed">16</vertical>
                            <horizontal method="fixed">16</horizontal>
                        </sizing>
                        <stack>minecraft:air</stack>
                        <show-overlay>true</show-overlay>
                    </item>
                </children>
                <sizing>
                    <vertical method="fixed">18</vertical>
                    <horizontal method="fixed">18</horizontal>
                </sizing>
            </flow-layout>
        </template>
        <template name="flatButton">
            <flow-layout direction="vertical" id="flatButton">
                <children>
                    <label id="button-text">
                        <text>{{button-text}}</text>
                        <color>#EAEAEA</color>
                        <vertical-text-alignment>center</vertical-text-alignment>
                    </label>
                </children>
                <surface>
                    <flat>#2A2A2A</flat>
                </surface>
                <sizing>
                    <horizontal method="fill">100</horizontal>
                    <vertical method="fill">100</vertical>
                </sizing>
                <vertical-alignment>center</vertical-alignment>
                <horizontal-alignment>center</horizontal-alignment>
            </flow-layout>
        </template>
    </templates>
</owo-ui>